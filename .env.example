# Copy to `.env.local` and fill in values. Never commit real secrets.

# --- Gemini (server) ---
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Twilio (voice webhooks) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Public base URL Twilio calls (ngrok or production), no trailing slash — required for valid signatures
TWILIO_WEBHOOK_BASE_URL=
# Dev only if signature URL mismatch while debugging:
# TWILIO_SKIP_SIGNATURE_VERIFY=true

# Optional: press 1 = English, 2 = Bangla before speech (IVR)
# TWILIO_VOICE_DTMF_MENU=true

# Optional: after each AI reply, ask “anything else?” (default on)
# TWILIO_VOICE_MULTI_TURN=false

# Optional: default voice agent id (Zustand seed ids, e.g. agent-support-1) stored on call_sessions
# VOICE_DEFAULT_AGENT_ID=agent-support-1
# Optional: plain-text KB snippet appended to Gemini voice system prompt (until RAG is wired)
# VOICE_KB_CONTEXT=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: enables call_sessions + voice_pipeline_events from Twilio routes
SUPABASE_SERVICE_ROLE_KEY=
# Vercel: add to Production (and Preview if needed). Without this, /api/voice/stats returns 503 in ~few ms.
# With both anon + service role: Settings → Webhooks streams those events into the live log (polling + Realtime if publication includes voice_pipeline_events; see supabase_schema.sql).

# Optional: same as TWILIO_WEBHOOK_BASE_URL for server-side CRM fetch from gather
# NEXT_PUBLIC_APP_URL=

# --- CRM proxy (optional) ---
# PRODUCTS_API_BASE=
# PRODUCTS_API_KEY=

# --- Dashboard security (recommended) ---
# Secret header required for the /api/voice/sessions/[callSid]/takeover endpoint.
# Set to a long random string; the dashboard must send X-Dashboard-Secret: <value>.
# DASHBOARD_SECRET=
